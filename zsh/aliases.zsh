# Navigation
alias ls='eza --icons'
alias home='cd'
alias ll='eza -la --icons'
alias y='yazi'
# alias v='nvim'

# Git
alias gs='git status'
alias ga='git add .'
alias gc='git commit -m'
alias gp='git push'

# Pacman
alias updateall='sudo pacman -Syu'
alias ins='sudo pacman -S'
alias psize='du -sh /var/cache/pacman/pkg'
alias cleancache='sudo paccache -r'

# Utilities
alias cls='clear'
alias fs='fastfetch'
alias reload='source ~/.zshrc'
alias hyprlua='nvim ~/.config/hypr/hyprland.lua'
alias vi='nvim'
